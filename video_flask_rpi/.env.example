# Flask app secret for sessions
SECRET_KEY=change-this-secret

# Shared folder mounted on Raspberry (SMB/NFS mount)
MEDIA_ROOT=/mnt/media_share

# Optional app log file
APP_LOG_PATH=/var/log/video_flask_rpi/app.log

# SQLite file for watched/favorites state
STATE_DB_PATH=./video_state.db

# Auth credentials (change these)
APP_USERNAME=admin
APP_PASSWORD=change-this-password

# ffmpeg binary path in Raspberry
FFMPEG_PATH=/usr/bin/ffmpeg

# Server bind
HOST=0.0.0.0
PORT=8080
